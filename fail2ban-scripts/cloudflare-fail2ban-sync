#!/bin/bash

# This script syncs all currently banned IPs from fail2ban to Cloudflare
# It generates a CSV of banned IPs and replaces the entire Cloudflare list
# Should be run via cron every 30 minutes
# Usage: cloudflare-fail2ban-sync

set -e

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load configuration
CONFIG_FILE="${SCRIPT_DIR}/cloudflare-fail2ban-config"
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE"
    echo "Copy cloudflare-fail2ban-config.example to cloudflare-fail2ban-config and configure it"
    exit 1
fi

source "$CONFIG_FILE"

# Validate required config
if [ -z "$CLOUDFLARE_LIST_ID" ]; then
    echo "ERROR: CLOUDFLARE_LIST_ID must be set in config"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -eq 0 ]; then
    echo "ERROR: At least one account ID must be configured in CLOUDFLARE_ACCOUNT_IDS array"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -ne ${#CLOUDFLARE_API_KEY_FILES[@]} ]; then
    echo "ERROR: Number of account IDs must match number of API key files"
    exit 1
fi

if [ ${#CLOUDFLARE_LIST_UUIDS[@]} -ne ${#CLOUDFLARE_ACCOUNT_IDS[@]} ]; then
    echo "ERROR: CLOUDFLARE_LIST_UUIDS count must match CLOUDFLARE_ACCOUNT_IDS — regenerate the config file"
    exit 1
fi

# Check if fail2ban-client is available
if ! command -v fail2ban-client &> /dev/null; then
    echo "ERROR: fail2ban-client not found. Is fail2ban installed?"
    exit 1
fi

# Create temporary directory for working files
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

CSV_FILE="${TEMP_DIR}/banned_ips.csv"

# Get list of all active jails
JAILS=$(fail2ban-client status | grep "Jail list:" | sed 's/.*Jail list://;s/,//g')

if [ -z "$JAILS" ]; then
    echo "No active fail2ban jails found"
    # If no jails, we should still clear the Cloudflare list
    JAILS=""
fi

echo "Collecting banned IPs from fail2ban..."

# Collect all banned IPs from all jails
> "$CSV_FILE"  # Create empty CSV file

for jail in $JAILS; do
    # Get banned IPs for this jail
    BANNED_IPS=$(fail2ban-client status "$jail" | grep "Banned IP list:" | sed 's/.*Banned IP list://' | tr -d '\t' | tr ' ' '\n' | grep -v '^$' || true)
    
    if [ -n "$BANNED_IPS" ]; then
        echo "  Jail '$jail': $(echo "$BANNED_IPS" | wc -l | tr -d ' ') banned IPs"
        
        # Add each IP to CSV with CIDR notation and description
        while read -r ip; do
            # Strip all whitespace/carriage returns
            ip=$(echo "$ip" | tr -d '\r\n\t ')
            if [ -z "$ip" ]; then
                continue
            fi
            # Validate: skip anything that isn't a plain IPv4 or IPv6 address
            if [[ ! "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] && [[ ! "$ip" =~ ^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$ ]]; then
                echo "  WARNING: Skipping invalid IP from fail2ban: '$ip'"
                continue
            fi
            # Add to CSV: ip,comment
            echo "${ip},\"Blocked by ${jail} on ${SERVER_NAME}\"" >> "$CSV_FILE"
        done <<< "$BANNED_IPS"
    fi
done

# Count total IPs
TOTAL_IPS=$(wc -l < "$CSV_FILE" | tr -d ' ')
echo "Total banned IPs collected: $TOTAL_IPS"

# Remove duplicates (in case an IP is banned in multiple jails, keep first occurrence)
sort -t',' -k1,1 -u "$CSV_FILE" -o "$CSV_FILE"

UNIQUE_IPS=$(wc -l < "$CSV_FILE" | tr -d ' ')
if [ "$TOTAL_IPS" -ne "$UNIQUE_IPS" ]; then
    echo "Removed $((TOTAL_IPS - UNIQUE_IPS)) duplicate IPs, unique IPs: $UNIQUE_IPS"
fi

# Now replace the entire Cloudflare list with this CSV for all accounts
# Uses PUT /items which replaces the full list in one API call per account,
# avoiding the GET + DELETE + POST cycle that triggers rate limits.
echo "Updating Cloudflare IP lists across all accounts..."

# Build a single JSON payload from the CSV (reused for every account)
PUT_PAYLOAD="${TEMP_DIR}/put_payload.json"
echo "[" > "$PUT_PAYLOAD"
FIRST_ITEM=1
while IFS= read -r line || [ -n "$line" ]; do
    if [ -z "$line" ]; then
        continue
    fi
    IP=$(echo "$line" | cut -d',' -f1)
    COMMENT=$(echo "$line" | cut -d',' -f2- | sed 's/^"//;s/"$//')
    if [ $FIRST_ITEM -eq 0 ]; then
        echo "," >> "$PUT_PAYLOAD"
    fi
    cat >> "$PUT_PAYLOAD" <<EOF
  {
    "ip": "$IP",
    "comment": "$COMMENT"
  }
EOF
    FIRST_ITEM=0
done < "$CSV_FILE"
echo "]" >> "$PUT_PAYLOAD"

HEADER_FILE="${TEMP_DIR}/response_headers.txt"

# Loop through each Cloudflare account
for i in "${!CLOUDFLARE_ACCOUNT_IDS[@]}"; do
    ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_IDS[$i]}"
    API_KEY_FILE="${CLOUDFLARE_API_KEY_FILES[$i]}"

    echo "Processing account ${ACCOUNT_ID:0:8}..."

    # Load API key for this account
    if [ ! -f "$API_KEY_FILE" ]; then
        echo "  ERROR: API key file not found: $API_KEY_FILE"
        continue
    fi

    API_KEY=$(cat "$API_KEY_FILE" | tr -d '\n\r ')

    # Use pre-resolved list UUID from config (avoids extra API call per sync run).
    LIST_UUID="${CLOUDFLARE_LIST_UUIDS[$i]}"
    if [ -z "$LIST_UUID" ]; then
        echo "  ERROR: No list UUID for account ${ACCOUNT_ID:0:8}... — regenerate the config file."
        continue
    fi

    # API endpoint for list items
    API_URL="https://api.cloudflare.com/client/v4/accounts/${ACCOUNT_ID}/rules/lists/${LIST_UUID}/items"

    if [ "$UNIQUE_IPS" -gt 0 ]; then
        echo "  Replacing list with $UNIQUE_IPS IPs (PUT)..."
    else
        echo "  Clearing list (PUT with empty array)..."
    fi

    # PUT replaces the entire list in one request — no delete step needed
    PUT_ATTEMPTS=0
    while [ $PUT_ATTEMPTS -lt 3 ]; do
        RESPONSE=$(curl -4 -s -D "$HEADER_FILE" -X PUT "$API_URL" \
            -H "Authorization: Bearer ${API_KEY}" \
            -H "Content-Type: application/json" \
            --data @"$PUT_PAYLOAD")

        if echo "$RESPONSE" | grep -qE '"success"[[:space:]]*:[[:space:]]*true'; then
            echo "  List updated successfully"
            break
        elif echo "$RESPONSE" | grep -q '"code":971'; then
            PUT_ATTEMPTS=$((PUT_ATTEMPTS + 1))
            RETRY_AFTER=$(grep -i '^retry-after:' "$HEADER_FILE" | awk '{print $2}' | tr -d '\r')
            CF_RAY=$(grep -i '^cf-ray:' "$HEADER_FILE" | awk '{print $2}' | tr -d '\r')
            WAIT=${RETRY_AFTER:-60}
            echo "  Rate limited (attempt $PUT_ATTEMPTS/3, CF-Ray: ${CF_RAY:-unknown})"
            echo "  Retry-After: ${RETRY_AFTER:-not provided} — waiting ${WAIT}s..."
            sleep "$WAIT"
        else
            CF_RAY=$(grep -i '^cf-ray:' "$HEADER_FILE" | awk '{print $2}' | tr -d '\r')
            echo "  ERROR: Failed to update list (CF-Ray: ${CF_RAY:-unknown})"
            echo "  Response: $RESPONSE"
            break
        fi
    done

    echo "  Account ${ACCOUNT_ID:0:8}... sync completed"

done  # End of account loop

# Log to syslog
logger -t cloudflare-fail2ban-sync "Synced $UNIQUE_IPS banned IPs to ${#CLOUDFLARE_ACCOUNT_IDS[@]} Cloudflare account(s)"

echo "All accounts synced. Done."
exit 0
