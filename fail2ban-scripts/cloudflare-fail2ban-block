#!/bin/bash

# This script is called by fail2ban when an IP is banned
# It adds the IP to a Cloudflare IP List immediately
# Usage: cloudflare-fail2ban-block <ip> <jail_name>

set -e

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load configuration
CONFIG_FILE="${SCRIPT_DIR}/cloudflare-fail2ban-config"
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE"
    echo "Copy cloudflare-fail2ban-config.example to cloudflare-fail2ban-config and configure it"
    exit 1
fi

source "$CONFIG_FILE"

# Validate required config
if [ -z "$CLOUDFLARE_LIST_ID" ]; then
    echo "ERROR: CLOUDFLARE_LIST_ID must be set in config"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -eq 0 ]; then
    echo "ERROR: At least one account ID must be configured in CLOUDFLARE_ACCOUNT_IDS array"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -ne ${#CLOUDFLARE_API_KEY_FILES[@]} ]; then
    echo "ERROR: Number of account IDs must match number of API key files"
    exit 1
fi

if [ ${#CLOUDFLARE_LIST_UUIDS[@]} -ne ${#CLOUDFLARE_ACCOUNT_IDS[@]} ]; then
    echo "ERROR: CLOUDFLARE_LIST_UUIDS count must match CLOUDFLARE_ACCOUNT_IDS — regenerate the config file"
    exit 1
fi
IP="$1"
JAIL_NAME="${2:-unknown}"

if [ -z "$IP" ]; then
    echo "Usage: $0 <ip> [jail_name]"
    exit 1
fi

# Validate IP format (basic check)
if ! echo "$IP" | grep -qE '^([0-9]{1,3}\.){3}[0-9]{1,3}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$'; then
    echo "ERROR: Invalid IP address format: $IP"
    exit 1
fi

# Create description with jail name and server
DESCRIPTION="Blocked by ${JAIL_NAME} on ${SERVER_NAME}"

# Prepare JSON payload for adding IP to list
# Note: Cloudflare expects CIDR notation, so append /32 for IPv4 or /128 for IPv6
if [[ "$IP" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
    IP_CIDR="${IP}/32"
else
    IP_CIDR="${IP}/128"
fi

JSON_PAYLOAD=$(cat <<EOF
[
  {
    "ip": "$IP_CIDR",
    "comment": "$DESCRIPTION"
  }
]
EOF
)

# Add IP to all configured Cloudflare accounts
SUCCESS_COUNT=0
FAIL_COUNT=0

for i in "${!CLOUDFLARE_ACCOUNT_IDS[@]}"; do
    ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_IDS[$i]}"
    API_KEY_FILE="${CLOUDFLARE_API_KEY_FILES[$i]}"
    
    # Load API key for this account
    if [ ! -f "$API_KEY_FILE" ]; then
        echo "ERROR: API key file not found: $API_KEY_FILE"
        FAIL_COUNT=$((FAIL_COUNT + 1))
        continue
    fi
    
    API_KEY=$(cat "$API_KEY_FILE" | tr -d '\n\r ')

    # Use pre-resolved list UUID from config (avoids extra API call per ban event).
    LIST_UUID="${CLOUDFLARE_LIST_UUIDS[$i]}"
    if [ -z "$LIST_UUID" ]; then
        echo "ERROR: No list UUID for account ${ACCOUNT_ID:0:8}... — regenerate the config file."
        FAIL_COUNT=$((FAIL_COUNT + 1))
        continue
    fi

    # API endpoint for adding items to list
    API_URL="https://api.cloudflare.com/client/v4/accounts/${ACCOUNT_ID}/rules/lists/${LIST_UUID}/items"
    
    # Add IP to Cloudflare list
    RESPONSE=$(curl -4 -s -X POST "$API_URL" \
        -H "Authorization: Bearer ${API_KEY}" \
        -H "Content-Type: application/json" \
        --data "$JSON_PAYLOAD")
    
    # Check if request was successful
    if echo "$RESPONSE" | grep -qE '"success"[[:space:]]*:[[:space:]]*true'; then
        echo "Successfully added $IP to Cloudflare account ${ACCOUNT_ID:0:8}... (jail: $JAIL_NAME)"
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
    else
        echo "ERROR: Failed to add $IP to Cloudflare account ${ACCOUNT_ID:0:8}..."
        echo "Response: $RESPONSE"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    fi
done

# Log results
if [ $SUCCESS_COUNT -gt 0 ]; then
    logger -t cloudflare-fail2ban "Added $IP to $SUCCESS_COUNT Cloudflare account(s) (jail: $JAIL_NAME)"
fi

if [ $FAIL_COUNT -gt 0 ]; then
    logger -t cloudflare-fail2ban "ERROR: Failed to add $IP to $FAIL_COUNT Cloudflare account(s) (jail: $JAIL_NAME)"
fi

# Exit with error if all accounts failed
if [ $SUCCESS_COUNT -eq 0 ]; then
    exit 1
fi

exit 0
