#!/bin/bash

# This script is called by fail2ban when an IP is unbanned
# It removes the IP from Cloudflare IP Lists immediately
# Usage: cloudflare-fail2ban-unban <ip> <jail_name>

set -e

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load configuration
CONFIG_FILE="${SCRIPT_DIR}/cloudflare-fail2ban-config"
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE"
    echo "Copy cloudflare-fail2ban-config.example to cloudflare-fail2ban-config and configure it"
    exit 1
fi

source "$CONFIG_FILE"

# Validate required config
if [ -z "$CLOUDFLARE_LIST_ID" ]; then
    echo "ERROR: CLOUDFLARE_LIST_ID must be set in config"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -eq 0 ]; then
    echo "ERROR: At least one account ID must be configured in CLOUDFLARE_ACCOUNT_IDS array"
    exit 1
fi

if [ ${#CLOUDFLARE_ACCOUNT_IDS[@]} -ne ${#CLOUDFLARE_API_KEY_FILES[@]} ]; then
    echo "ERROR: Number of account IDs must match number of API key files"
    exit 1
fi

if [ ${#CLOUDFLARE_LIST_UUIDS[@]} -ne ${#CLOUDFLARE_ACCOUNT_IDS[@]} ]; then
    echo "ERROR: CLOUDFLARE_LIST_UUIDS count must match CLOUDFLARE_ACCOUNT_IDS — regenerate the config file"
    exit 1
fi

# Get parameters
IP="$1"
JAIL_NAME="${2:-unknown}"

if [ -z "$IP" ]; then
    echo "Usage: $0 <ip> [jail_name]"
    exit 1
fi

# Validate IP format (basic check)
if ! echo "$IP" | grep -qE '^([0-9]{1,3}\.){3}[0-9]{1,3}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}$'; then
    echo "ERROR: Invalid IP address format: $IP"
    exit 1
fi

# Remove IP from all configured Cloudflare accounts
SUCCESS_COUNT=0
FAIL_COUNT=0

for i in "${!CLOUDFLARE_ACCOUNT_IDS[@]}"; do
    ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_IDS[$i]}"
    API_KEY_FILE="${CLOUDFLARE_API_KEY_FILES[$i]}"
    
    # Load API key for this account
    if [ ! -f "$API_KEY_FILE" ]; then
        echo "ERROR: API key file not found: $API_KEY_FILE"
        FAIL_COUNT=$((FAIL_COUNT + 1))
        continue
    fi
    
    API_KEY=$(cat "$API_KEY_FILE" | tr -d '\n\r ')

    # Use pre-resolved list UUID from config (avoids extra API call per unban event).
    LIST_UUID="${CLOUDFLARE_LIST_UUIDS[$i]}"
    if [ -z "$LIST_UUID" ]; then
        echo "ERROR: No list UUID for account ${ACCOUNT_ID:0:8}... — regenerate the config file."
        FAIL_COUNT=$((FAIL_COUNT + 1))
        continue
    fi

    # API endpoint for list items
    API_URL="https://api.cloudflare.com/client/v4/accounts/${ACCOUNT_ID}/rules/lists/${LIST_UUID}/items"
    
    # Get all items in the list to find the one matching our IP
    RESPONSE=$(curl -s -X GET "$API_URL" \
        -H "Authorization: Bearer ${API_KEY}" \
        -H "Content-Type: application/json")
    
    # Extract the item ID for this IP using jq
    ITEM_ID=$(echo "$RESPONSE" | jq -r --arg ip "$IP" '.result[] | select(.ip == $ip) | .id')
    
    if [ -z "$ITEM_ID" ]; then
        echo "IP $IP not found in Cloudflare account ${ACCOUNT_ID:0:8}... (may have already been removed)"
        continue
    fi
    
    # Delete the item
    DELETE_PAYLOAD=$(cat <<EOF
{
  "items": [
    {"id": "$ITEM_ID"}
  ]
}
EOF
)
    
    DELETE_RESPONSE=$(curl -s -X DELETE "$API_URL" \
        -H "Authorization: Bearer ${API_KEY}" \
        -H "Content-Type: application/json" \
        --data "$DELETE_PAYLOAD")
    
    # Check if request was successful
    if echo "$DELETE_RESPONSE" | grep -qE '"success"[[:space:]]*:[[:space:]]*true'; then
        echo "Successfully removed $IP from Cloudflare account ${ACCOUNT_ID:0:8}... (jail: $JAIL_NAME)"
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
    else
        echo "ERROR: Failed to remove $IP from Cloudflare account ${ACCOUNT_ID:0:8}..."
        echo "Response: $DELETE_RESPONSE"
        FAIL_COUNT=$((FAIL_COUNT + 1))
    fi
done

# Log results
if [ $SUCCESS_COUNT -gt 0 ]; then
    logger -t cloudflare-fail2ban "Removed $IP from $SUCCESS_COUNT Cloudflare account(s) (jail: $JAIL_NAME)"
fi

if [ $FAIL_COUNT -gt 0 ]; then
    logger -t cloudflare-fail2ban "ERROR: Failed to remove $IP from $FAIL_COUNT Cloudflare account(s) (jail: $JAIL_NAME)"
fi

# Don't exit with error if IP wasn't found (it's already gone, which is the desired state)
exit 0
